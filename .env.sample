# Google OAuth — client ID (exposed to the browser for login URL generation)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id

# Google OAuth — redirect URI registered in Google Cloud Console
# Default when unset: http://localhost:3000/oauth/callback/google
NEXT_PUBLIC_REDIRECT_URI=http://localhost:3000/oauth/callback/google

# Google OAuth — client secret (server-only; used in /api/oauth/callback)
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# OpenAI — API key for trip plan generation (/api/chat)
OPENAI_API_KEY=your-openai-api-key

# Google Maps — JavaScript API key for TripRouteMap (optional; map falls back to empty key)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
