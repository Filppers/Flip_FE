# Google OAuth — 클라이언트 ID (로그인 URL 생성 시 브라우저에 노출)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id

# Google OAuth — Google Cloud Console에 등록된 리다이렉트 URI
# 미설정 시 기본값: http://localhost:3000/oauth/callback/google
NEXT_PUBLIC_REDIRECT_URI=http://localhost:3000/oauth/callback/google

# Google OAuth — 클라이언트 시크릿 (서버 전용; /api/oauth/callback에서 사용)
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# OpenAI — 여행 일정 생성용 API 키 (/api/chat)
OPENAI_API_KEY=your-openai-api-key

# Google Maps — TripRouteMap용 JavaScript API 키 (선택; 미설정 시 빈 키로 폴백)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
